 AbacusDark‚Üê{
     r‚Üê##.Main.NewRule':root'
     ‚çù Typography
     r.font_family‚Üê'Arial'                  ‚çù System default
     r.font_size‚Üê'20px'                     ‚çù System default
     r.__system_font_family‚Üêr.font_family   ‚çù In case needed when not inherited
     r.__system_font_size‚Üêr.font_size       ‚çù In case needed when not inherited
     r.__user_input_font_family‚Üê'APL385 Unicode'
     r.__code_font_family‚Üê'APL385 Unicode'
     ‚çù Borders
     r.__border_radius‚Üê'.5rem'
     r.__border‚Üê'2px solid #E5E7EB'
     r.__border_focused‚Üê'3px solid #60A5FA'  ‚çù Was 2
     ‚çù r.__border_box_shadow_focused‚Üê'0 0 0 3px rgba(96,165,250,0.35)'

     r.__border_box_shadow_focused‚Üê'0 0 0 1px #60A5FA, 0 0 0 4px rgba(96,165,250,.25)'

     ‚çù Colors
     r.__text_color‚Üê'hsl(0, 0%, 90%)'
     r.__background_color‚Üê'hsl(230, 10%, 15%)' ‚çù Was 240 10 10
     r.__selected_background_color‚Üê'hsl(0, 0%, 60%)'
     r.__selected_text_color‚Üê'white'
     r.__border_color‚Üê'hsl(0, 0%, 80%)' ‚çù Compute from background?
     r.__border_focused_color‚Üê'#3B82F6'

     r.__accent_color_1‚Üê'steelblue'
     r.__accent_color_2‚Üê'orange'
     ‚çù ***********************
     r
 }
