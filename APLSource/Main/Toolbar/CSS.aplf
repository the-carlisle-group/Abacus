 CSS‚Üê{
     Rule‚ÜêA.NewRule
     ‚çù *********************
     s‚ÜêRule'.Toolbar'
     s.display‚Üê'flex'
     s.gap‚Üê'.5rem'
     s.padding‚Üê'0'
     s.background‚Üê'#2b2b2b'
     s.border_top‚Üê'3px solid #555'
     s.border_left‚Üê'3px solid #555'
     s.border_bottom‚Üê'3px solid #111'
     s.border_right‚Üê'3px solid #111'
     ‚çù Active Item
     r‚Üês Rule'.Active'
     r.border‚Üê'2px solid gray'


     ‚çù Or tweak components here?
     r‚Üês Rule'.Button,.CheckBox,.DropList,.dropdown-menu'
     ‚çù r‚Üês Rule'.Toolbar > *'
     r.min_width‚Üê'0'
     r.border‚Üê'3px solid #2b2b2b'
     r.border_radius‚Üê'0'


     ‚çù All Direct Children
     r‚Üês Rule'>*:hover'
     r.border_left‚Üê'3px solid #555'
     r.border_right‚Üê'3px solid #111'


     ‚çù All Direct Children
     r‚Üês Rule'.dropdown-menu:hover'
     r.border_left‚Üê'3px solid #555'
     r.border_right‚Üê'3px solid #111'


     r‚Üês Rule'.Button:focus'
     r.border_radius‚Üê'var(--border-radius)'





     ‚çù
     r‚Üês Rule'.CheckBox'
     r.padding‚Üê'0 .5rem'

     ‚çù
     r‚Üês Rule'.DropList'
     ‚çù r.border_radius‚Üê'var(--border-radius)'
     r.padding‚Üê'0 .5rem'
     r.flex_direction‚Üê'row'
     r.gap‚Üê'.1REM'
     r.align_items‚Üê'center'

     r‚Üês Rule'.DropList select'
     r.border‚Üê'3px solid #2b2b2b'
     r.padding‚Üê'.5rem 0'
     ‚çù r.border‚Üê'none'


     r‚Üês Rule'.DropList select:focus,.dropdown-menu:focus'
     r.border‚Üê'var(--border-focused)'
     r.box_shadow‚Üê'var(--border-box-shadow-focused)'


     r‚Üês Rule'.dropdown-menu'
     r.border‚Üê'3px solid #2b2b2b'


     s
 }
