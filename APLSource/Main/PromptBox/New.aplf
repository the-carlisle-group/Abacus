 New←{
     ⍺←0
     w←(
         'Title' ''
         'Label' ''
         'Value' ''
         'OnOK' ''
         'OnCancel' ''
         '_width' '30rem'
     )A.Default ⍵
     PromptBox←A.TextInput.New w.Label w.Value
     p←()
     p.Title←w.Title
     p.MainContent←PromptBox
     p.OnClick←A.FQP¨'OnOK' 'OnCancel'
     p.OnCancel←A.FQP'OnCancel'
     d←⍺ A.DialogBox.New p
     d.OnCancelPromptBox←w.OnCancel
     d ⎕NS w⊣w.⎕EX d.⎕NL 2
 }
