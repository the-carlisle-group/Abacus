 CSS‚Üê{
     Rule‚Üê##.NewRule
     ‚çù *********************
     s‚ÜêRule'.tabs'
     ‚çù *****************
     r‚Üês Rule'nav'
     r.display‚Üê'flex'
     r.gap‚Üê'.25rem'
     r.padding‚Üê'.35rem .5rem 0 .5rem' ‚çù top+side room; no bottom so tabs meet the content's top edge
     r.border_bottom‚Üê'1px solid var(--border-color)' ‚çù the tab strip owns its baseline (stable, independent of the panel's own border)
     ‚çù *********************
     ‚çù Every tab: a boxed "folder" with rounded top corners (not an all-round button)
     r‚Üês Rule'>nav>button'
     r.font‚Üê'inherit'               ‚çù constant size, matches page text (no small inactive tab)
     r.padding‚Üê'.4rem 1rem'
     r.border‚Üê'1px solid var(--border-color)'
     r.border_bottom‚Üê'none'
     r.border_top_left_radius‚Üê'7px'
     r.border_top_right_radius‚Üê'7px'
     r.margin_bottom‚Üê'-1px'         ‚çù overlap the content's top border
     r.background_color‚Üê'color-mix(in srgb, currentColor 10%, transparent)' ‚çù subtle raised chip, theme-adaptive
     r.color‚Üê'inherit'              ‚çù take the theme's text colour (dark & light)
     r.opacity‚Üê'.8'                 ‚çù muted while inactive
     r.cursor‚Üê'pointer'
     ‚çù ******************
     r‚Üês Rule'>nav>button:hover'
     r.opacity‚Üê'1'
     r.background_color‚Üê'color-mix(in srgb, currentColor 18%, transparent)'
     ‚çù ******************
     r‚Üês Rule'>section'
     r.flex‚Üê1
     ‚çù A DataGrid used as a tab panel must not draw its own top edge: the tab strip's
     ‚çù baseline is that line, and the active tab connects into the grid across it.
     r‚Üês Rule'section .DataGrid thead th'
     r.border_top_color‚Üê'transparent'
     ‚çù Active tab: connects into the content (never a bigger font)
     r‚Üês Rule'.active-tab'
     r.opacity‚Üê'1'
     r.color‚Üê'var(--text-color)' ‚çù  'var(--selected-text-color)'
     r.background_color‚Üê'var(--background-color)'    ‚çù merge with the panel below
     r.position‚Üê'relative'          ‚çù lift above the panel, which is painted later in the DOM‚Ä¶
     r.z_index‚Üê'1'                  ‚çù ‚Ä¶so the cover below actually lands on top of the grid's line
     r.border_bottom‚Üê'1px solid var(--background-color)' ‚çù cut the line under the active tab
     ‚çù **************
     A.UnNestCSS s
 }
