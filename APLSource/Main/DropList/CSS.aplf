 CSS‚Üê{
     Rule‚ÜêA.NewRule
     ‚çù ************************
     s‚ÜêRule'.DropList'
     s.display‚Üê'flex'
     s.flex_direction‚Üê'column'
     s.gap‚Üê'.5rem'
     ‚çù ***********************************
     r‚Üês Rule'select' ‚çù ,::picker(select)'
     r.border‚Üê'2px solid var(--border-color)'
     r.appearance‚Üê'base-select'
     r.padding‚Üê'.5rem'
     ‚çù ***************************
     r‚Üês Rule'select:focus'
     r.border‚Üê'var(--border-focused)'
     r.box_shadow‚Üê'var(--border-box-shadow-focused)'


     ‚çù **********************************
     r‚Üês Rule'option:focus'
     r.background_color‚Üê'var(--accent-color-1)'



     ‚çù *****************************
     r‚Üês Rule'select::picker-icon'
     r.color‚Üê'#999'
     r.transition‚Üê'0.4s rotate'
     ‚çù ********************
     r‚Üês Rule'select:open::picker-icon'
     r.rotate‚Üê'180deg'




     ‚çù *********************
     r‚Üês Rule'option'
     r.gap‚Üê'5px'
     r.border_radius‚Üê'5px'
     r.padding‚Üê'.5rem'
     ‚çù *****************************
     r‚Üês Rule'option:checked'
     r.font_weight‚Üê'bold'
     ‚çù ******************
     r‚Üês Rule'select::picker(select)' ‚çù NEED SPACE!
     r.padding‚Üê'.5rem'
     r.border_radius‚Üê'10px'
     r.appearance‚Üê'base-select'
     r.color‚Üê'var(--text-color)'
     r.background_color‚Üê'var(--background-color)'

     ‚çù **************************
     A.UnNestCSS s
 }
