 ShowMenu←{
     ⍝ ⍺ ←→ Menu
     ⍝ ⍵ ←→ Anchor positionArea
     a p←2↑⍵,⊂'bottom span-right'
     ⍺.Onkeydown←A.FQP'OnKeyDown'
     ⍺.Onclick←A.FQP'OnClick'
     b←A.GetBody a.Document
     _←b A.AppendChild ⍺
     _←⍺ A.SetStyle'positionArea'p
     _←⍺ A.ExecuteOnElement'showPopover({source:document.getElementById("',a.id,'")})'
     ⍺ A.ExecuteOnElement'focus()'
 }
