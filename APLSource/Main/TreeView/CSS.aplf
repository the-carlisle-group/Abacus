 CSS‚Üê{
     Rule‚Üê##.NewRule
     ‚çù *********************
     s‚ÜêRule'.TreeView'
     s.overflow‚Üê'auto'
     s.list_style_type‚Üê'none'
     ‚çù r‚Üês Rule'&:focus'
     ‚çù r.border‚Üê'3px solid white'

     ‚çù All uls below
     r‚Üês Rule'ul'
     r.padding_left‚Üê'1rem'
     r.list_style_type‚Üê'none'

     ‚çù The item in any state
     r‚Üês Rule'.Item'
     r.border‚Üê'2px solid var(--background-color)'
     r.border_radius‚Üê'10px'
     ‚çù r.padding‚Üê'.2rem .5rem' ‚çù NO Padding, leave up to caller
     r.width‚Üê'100%'

     ‚çù Active Item
     r‚Üês Rule'.Active'
     r.border‚Üê'2px solid gray'

     ‚çù Active and focused Item
     r‚Üês Rule'&:focus .Active'
     r.border‚Üê'2px solid steelblue'

     ‚çù Chevron
     r‚Üês Rule'.Chevron>svg'
     r.height‚Üê'1.5rem'
     r.width‚Üê'auto'
     r.stroke_width‚Üê3

     ‚çù ******* Parent Node: <li> with <ul> below
     r‚Üês Rule'li:has(ul)'
     ‚çù r.padding_top‚Üê'.5rem'
     ‚çù r.padding_bottom‚Üê'.5rem'
     ‚çù r.padding_left‚Üê'.2rem'
     ‚çù ******* Parent Node: <li> with <ul> below
     ‚çùr‚Üês Rule'li:has(ul)>div'
‚çù     r.display‚Üê'flex'
‚çù     r.gap‚Üê'1rem'

     ‚çù  ******* Parent node <button> and li content
     sr‚Üêr Rule'>div'
     sr.display‚Üê'flex'
     sr.align_items‚Üê'center'
     ‚çù sr.gap‚Üê'1rem'
‚çù
     ‚çù ******* Leaf Node: <li> with no <ul> below
     r‚Üês Rule'li:not(:has(ul))'
     r.padding_left‚Üê'1.5rem'
     r‚Üês Rule'.retracted>ul'
     r.display‚Üê'none'

     ‚çù
     s2‚ÜêRule'.TabStyle'
     s2.display‚Üê'flex'
     s2.padding‚Üê'1rem'
     ‚çù *****************
     s,s2
     ‚çù A.UnNestCSS s
 }
