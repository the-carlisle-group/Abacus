 InitGlobalShortcuts←{
     d←⍵
     d.GlobalShortcuts←''
     d.GlobalMenuItems←''
     b←⊃,/d GetElementsByClass¨'MenuBar' 'HamburgerMenu'
     0=≢b:0
     f←(⊃b).BuildFunction
     m←d(⍎f)0
     i←{⍵/⍨⍵.Type∊⊂'Item'}m GetElementsByTag'li'
     s←∊¨2⊃¨i.Content.Content.Content
     s←{r←'+'(≠⊆⊢)⍵ ⋄ b←r∊,¨⎕A ⋄ ∊r,⍨¨b/¨⊂'Key'}¨s
     k←~s∊⊂''
     ~∨/k:0
     i.Document←d
     d.GlobalShortcuts←k/s
     d.GlobalMenuItems←k/i
     b←GetBody d
     b.Onkeydown←'OnKeyDown'
     0
 }
