 InitGlobalShortcuts←{
     d←⍵
     e←GetElements d
     e,←{
         b←⊃,/d GetElementsByClass¨'MenuBar' 'HamburgerMenu'
         0=≢b:⍬
         f←(⊃b).BuildFunction
         GetElements d(⍎f)0
     }0
     s←e ⎕VGET⊂'Shortcut' ''
     s←{r←'+'(≠⊆⊢)⍵ ⋄ b←r∊,¨⎕A ⋄ ∊r,⍨¨b/¨⊂'Key'}¨s
     k←~s∊⊂''
     d.GlobalShortcuts←k/s
     d.GlobalComponents←k/e
     0
 }
