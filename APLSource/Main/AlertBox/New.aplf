 New←{
     ⍺←0
     w←(
         'Title' 'Alert'
         'Message' ''
         '_min_width' '20rem'
         '_max_width' '40rem'
     )A.Default ⍵
     p←()
     p.MainContent←A.New¨{'p'⍵}¨⊆w.Message
     p.Buttons←'OK'
     p.Title←w.Title
     d←⍺ A.DialogBox.New p
     d ⎕NS w⊣w.⎕EX d.⎕NL 2
 }
