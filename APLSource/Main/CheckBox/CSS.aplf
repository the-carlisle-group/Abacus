 CSS‚Üê{
     Rule‚ÜêA.NewRule
     ‚çù ************************
     s‚ÜêRule'.CheckBox'
     s.display‚Üê'flex'
     s.align_items‚Üê'center'
     s.gap‚Üê'.5rem'
     ‚çù *******************************
     r‚Üês Rule'input'
     r.position‚Üê'relative'
     r.width‚Üê'1.75rem'
     r.height‚Üê'1.75rem'
     r.appearance‚Üê'none'
     r.border_radius‚Üê'5px'
     r.border‚Üê'var(--border)'
     ‚çù ***************************
     r‚Üês Rule'input:focus'
     r.border‚Üê'var(--border-focused)'
     r.box_shadow‚Üê'var(--border-box-shadow-focused)'

     ‚çù ****************************
     ‚çù r‚Üês Rule'input:checked'
     ‚çù r.background_color‚Üê'red'



     ‚çù ****************************
     r‚Üês Rule'input:checked::before'
     r.content‚Üê'"',(‚éïUCS 10004),'"'
     r.position‚Üê'absolute'
     r.top‚Üê'50%'
     r.left‚Üê'50%'
     r.transform‚Üê'translate(-50%, -50%)'
     r.color‚Üê'white'
     r.font_size‚Üê'1rem'

     s

     A.UnNestCSS s
 }
