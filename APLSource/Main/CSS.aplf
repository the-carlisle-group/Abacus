 CSS‚Üê{
     ‚çù Main CSS for Abacus Applications
     ‚çù ‚çµ ‚Üê‚Üí Theme
     Rule‚ÜêNewRule
     s‚ÜêRule''
     ‚çù Reset
     r‚Üês Rule'*'
     r.margin‚Üê0
     r.padding‚Üê0
     r.box_sizing‚Üê'border-box'

     r.outline‚Üê'none'

     ‚çù Flex Containers
     r‚Üês Rule'body, main, .tabs, .flex'
     r.display‚Üê'flex'
     r.flex_direction‚Üê'column'
     r.flex‚Üê1
     ‚çù Body
     r‚Üês Rule'body'
     r.border‚Üê0
     r.height‚Üê'100vh'
     r.width‚Üê'100vw'
     r.user_select‚Üê'none'
     r.color‚Üê'var(--text-color)'
     r.background_color‚Üê'var(--background-color)'
     ‚çù Header
     r‚Üês Rule'body>header'
     r.border‚Üê'solid 1px var(--border-color)'
     r.padding‚Üê'1rem'
     ‚çù Main
     r‚Üês Rule'main'
     r.border‚Üê'solid 1px var(--border-color)'
     ‚çù Footer
     r‚Üês Rule'body>footer'
     r.border‚Üê'solid 1px var(--border-color)'
     r.padding‚Üê'.5rem'
     r.height‚Üê'5rem'
     ‚çù Input
     r‚Üês Rule' '
‚çù     r.font_family‚Üê'var(--user-input-font-family)'
‚çù     r.font_size‚Üê'1rem'
‚çù     r.color‚Üê'inherit'
‚çù     r.background_color‚Üê'inherit'
‚çù     r.padding‚Üê'.5rem'
‚çù     r.border‚Üê'2px solid'
‚çù     r.border_radius‚Üê'var(--border-radius)'
     ‚çù Button
     r‚Üês Rule'button'
     r.border_radius‚Üê'var(--border-radius)'
     r.padding‚Üê'.5rem'
     r.color‚Üê'inherit'
     r.background_color‚Üê'inherit'
     r.border‚Üê'2px solid var(--accent-color-1)'
     r.font_size‚Üê'1rem'
     r.min_width‚Üê'6rem'
     ‚çù Icons
     r‚Üês Rule'.icon-tabler'
     r.color‚Üê'lightgray'
     ‚çùr.width‚Üê'2rem'
     ‚çùr.height‚Üê'2rem'
     ‚çù ***************************

     ‚çù
     r‚Üês Rule'.aui-IconButton>svg'
     r.height‚Üê'48px'
     r.width‚Üê'auto'


     ‚çù **************
     r‚Üês Rule'#MouseAnchor'
     r.anchor_name‚Üê'--mouse-anchor'
     r.position‚Üê'absolute'
     s
 }
